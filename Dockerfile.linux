FROM golang:1.25-bookworm AS builder
RUN apt-get update && apt-get install -y --no-install-recommends gcc libc6-dev libsqlite3-dev && rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
ARG BUILD_TAGS=sqlite_fts5
RUN CGO_ENABLED=1 go build -tags "${BUILD_TAGS}" -ldflags="-w -s" -o marrow .
