# Marrow environment variables
# Copy this file to .env and fill in your values, or source it before running.

# Server
MARROW_SERVER_ADDR=:8080
MARROW_SERVER_DB=/data/marrow.db
MARROW_SERVER_LOG_FORMAT=json
MARROW_SERVER_SYNC_INTERVAL=15m

# Global security (applied when no site-specific config exists)
MARROW_SERVER_API_KEY=
MARROW_SERVER_RATE_LIMIT_RPS=0
MARROW_SERVER_RATE_LIMIT_SEARCH_RPS=0
MARROW_SERVER_MAX_BODY_SIZE=1048576
MARROW_SERVER_CORS_ORIGINS=

# Embedding provider (required)
# Options: mock, ollama, openai
MARROW_EMBEDDING_PROVIDER=ollama
MARROW_EMBEDDING_MODEL=nomic-embed-text
MARROW_EMBEDDING_BASE_URL=http://localhost:11434
MARROW_EMBEDDING_API_KEY=

# Site 1 (blog)
MARROW_SITES_0_NAME=blog
MARROW_SITES_0_HOSTS=search.blog.example.com
MARROW_SITES_0_SOURCES=blog-docs
MARROW_SITES_0_API_KEY=change-me-blog-key
MARROW_SITES_0_RATE_LIMIT_RPS=20
MARROW_SITES_0_CORS_ORIGINS=

# Site 2 (docs)
MARROW_SITES_1_NAME=docs
MARROW_SITES_1_HOSTS=search.docs.example.com
MARROW_SITES_1_SOURCES=docs-site
MARROW_SITES_1_API_KEY=change-me-docs-key
MARROW_SITES_1_RATE_LIMIT_RPS=10
MARROW_SITES_1_CORS_ORIGINS=

# GitHub token for private repo sync
MARROW_GITHUB_REPO_TOKEN=
